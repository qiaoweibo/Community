<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qwb.community.project.system.qwbCarApply.mapper.QwbCarApplyMapper">
    
    <resultMap type="QwbCarApply" id="QwbCarApplyResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="phone"    column="phone"    />
        <result property="applyTime"    column="applyTime"    />
        <result property="state"    column="state"    />
        <result property="agreeTime"    column="agreeTime"    />
        <result property="cId"    column="cId"    />

        <result property="room"    column="room"    />
        <result property="rentTime"    column="rentTime"    />
        <result property="agreeName"    column="agreeName"    />
<!--以下是关联车位表的操作-->
        <association property="qwbCarRent" javaType="QwbCarRent">
            <id property="id" column="cId"/>
            <result property="carId"    column="carId"    />
            <result property="space"    column="space"    />
<!--            <result property="length"    column="length"    />-->
<!--            <result property="width"    column="width"    />-->
            <result property="area"    column="area"    />
<!--            <result property="ageLimit"    column="ageLimit"    />-->
            <result property="rentMoney"    column="rentMoney"    />
<!--            <result property="publishId"    column="publishId"    />-->
            <result property="pName"    column="pName"    />
            <result property="pNumber"    column="pNumber"    />
            <result property="pTime"    column="pTime"    />
<!--            <result property="state"    column="state"    />-->

            <result property="describe"    column="describe"    />
        </association>
    </resultMap>

    <sql id="selectQwbCarApplyVo">
        select a.id, a.name, a.phone, a.applyTime, a.state, a.agreeTime, a.cId, a.room ,a.rentTime ,a.agreeName,
         b.space ,b.carId ,b.area ,b.rentMoney ,b.pName ,b.pNumber ,b.pTime ,b.describe
        from qwb_car_apply a
        left  join qwb_car_rent b on a.cId=b.id
    </sql>
	
    <select id="selectQwbCarApplyList" parameterType="QwbCarApply" resultMap="QwbCarApplyResult">
        <include refid="selectQwbCarApplyVo"/>
        <where>  
            <if test="id != null "> and a.id = #{id}</if>
             <if test="name != null  and name != '' "> and a.name = #{name}</if>
             <if test="phone != null  and phone != '' "> and a.phone = #{phone}</if>
             <if test="applyTime != null "> and a.applyTime = #{applyTime}</if>
             <if test="state != null "> and a.state = #{state}</if>
             <if test="agreeTime != null "> and a.agreeTime = #{agreeTime}</if>
             <if test="cId != null "> and a.cId = #{cId}</if>

            <if test="room != null and room !='' "> and a.room = #{room}</if>
            <if test="rentTime != null "> and a.rentTime = #{rentTime}</if>
            <if test="agreeName != null  and agreeName != '' "> and a.agreeName = #{agreeName}</if>
         </where>
    </select>
    
    <select id="selectQwbCarApplyById" parameterType="Integer" resultMap="QwbCarApplyResult">
        <include refid="selectQwbCarApplyVo"/>
        where a.id = #{id}
    </select>



    <!--如果数据库没有√选自增长加上useGeneratedKeys="true" keyProperty="id"即可-->
    <insert id="insertQwbCarApply" parameterType="QwbCarApply" useGeneratedKeys="true" keyProperty="id">
        insert into qwb_car_apply
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="id != null  ">id,</if>
			<if test="name != null  and name != ''  ">name,</if>
			<if test="phone != null  and phone != ''  ">phone,</if>
			<if test="applyTime != null  ">applyTime,</if>
			<if test="state != null  ">state,</if>
			<if test="agreeTime != null  ">agreeTime,</if>
			<if test="cId != null  ">cId,</if>

            <if test="room != null  and room != ''  ">room,</if>
            <if test="rentTime != null  ">rentTime,</if>
            <if test="agreeName != null  and agreeName != ''  ">agreeName,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="id != null  ">#{id},</if>
			<if test="name != null  and name != ''  ">#{name},</if>
			<if test="phone != null  and phone != ''  ">#{phone},</if>
			<if test="applyTime != null  ">#{applyTime},</if>
			<if test="state != null  ">#{state},</if>
			<if test="agreeTime != null  ">#{agreeTime},</if>
			<if test="cId != null  ">#{cId},</if>

            <if test="room != null  and room != ''  ">#{room},</if>
            <if test="rentTime != null  ">#{rentTime},</if>
            <if test="agreeName != null  and agreeName != ''  ">#{agreeName},</if>
         </trim>
    </insert>
	 
    <update id="updateQwbCarApply" parameterType="QwbCarApply">
        update qwb_car_apply
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null  and name != ''  ">name = #{name},</if>
            <if test="phone != null  and phone != ''  ">phone = #{phone},</if>
            <if test="applyTime != null  ">applyTime = #{applyTime},</if>
            <if test="state != null  ">state = #{state},</if>
            <if test="agreeTime != null  ">agreeTime = #{agreeTime},</if>
            <if test="cId != null  ">cId = #{cId},</if>

            <if test="room != null  and room != ''  ">room = #{room},</if>
            <if test="rentTime != null  ">rentTime = #{rentTime},</if>
            <if test="agreeName != null  and agreeName != ''  ">agreeName = #{agreeName},</if>
        </trim>
        where id = #{id}
    </update>

	<delete id="deleteQwbCarApplyById" parameterType="Integer">
        delete from qwb_car_apply where id = #{id}
    </delete>
	
    <delete id="deleteQwbCarApplyByIds" parameterType="String">
        delete from qwb_car_apply where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
</mapper>