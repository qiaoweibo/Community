<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qwb.community.project.system.qwbCost.mapper.QwbCostMapper">
    
    <resultMap type="QwbCost" id="QwbCostResult">
        <result property="id"    column="id"    />
        <result property="name"    column="name"    />
        <result property="createDate"    column="create_date"    />
        <result property="electricityCosts"    column="electricity_costs"    />
        <result property="waterCosts"    column="water_costs"    />
        <result property="gasCosts"    column="gas_costs"    />
        <result property="propertyCosts"    column="property_costs"    />
        <result property="paymentTime"    column="payment_time"    />
        <result property="state"    column="state"    />

        <!--==================================================-->
        <result property="room"    column="room"    />
<!--        <association property="room"    column="room" javaType="User" resultMap="UserResult" />-->
        <!--<result property="check"    column="check"    />-->
        <result property="total"    column="total"    />
        <!--==================================================-->
        </resultMap>


    <!--===============2019-4-24-9:00====================-->
    <resultMap type="User" id="UserResult">
            <id     property="userId"       column="user_id"      />
            <result property="room"       column="room"      />
        </resultMap>
    <!--==================================================-->


	<sql id="selectQwbCostVo">
        select id, name, create_date, electricity_costs, water_costs, gas_costs, property_costs, payment_time,
        state ,room ,total
         from qwb_cost
    </sql>

 <!--以下是用于统计已交费和未交费的饼状图的查询语句 (五个饼状图)-->
    <!--电费(注意count(state) as value是记录 ‘state’的个数)-->
    <select id="selectElectricity" resultType="java.util.Map">
         SELECT
			SUM(electricity_costs) as value,
			'已交电费' AS name
		FROM
			qwb_cost
		WHERE
			state = '1'

    </select>
    <select id="selectNoElectricity" resultType="java.util.Map">
		SELECT
			SUM(electricity_costs) as value,
			'未交电费' AS name
		FROM
			qwb_cost
		WHERE
			state = '0'
    </select>
<!--水费-->
    <select id="selectWater" resultType="java.util.Map">
        SELECT
			SUM(water_costs) as value,
			'已交水费' AS name
		FROM
			qwb_cost
		WHERE
			state = '1'
    </select>
    <select id="selectNoWater" resultType="java.util.Map">
        SELECT
			SUM(water_costs) as value,
			'未交水费' AS name
		FROM
			qwb_cost
		WHERE
			state = '0'
    </select>
<!--燃气费-->
    <select id="selectGas" resultType="java.util.Map">
SELECT
        SUM(gas_costs) as value,
			'已交燃气费' AS name
		FROM
			qwb_cost
		WHERE
			state = '1'
    </select>
    <select id="selectNoGas" resultType="java.util.Map">
SELECT
 SUM(gas_costs) as value,
			'未交燃气费' AS name
		FROM
			qwb_cost
		WHERE
			state = '0'
    </select>
<!--物业费-->
    <select id="selectProperty" resultType="java.util.Map">
SELECT
 SUM(property_costs) as value,
			'已交物业费' AS name
		FROM
			qwb_cost
		WHERE
			state = '1'
    </select>
    <select id="selectNoProperty" resultType="java.util.Map">
SELECT
        SUM(property_costs) as value,
			'未交物业费' AS name
		FROM
			qwb_cost
		WHERE
			state = '0'
    </select>
<!--总计费用-->
    <select id="selectTotal" resultType="java.util.Map">
SELECT
        SUM(total) as value,
			'已交费用' AS name
		FROM
			qwb_cost
		WHERE
			state = '1'
    </select>
    <select id="selectNoTotal" resultType="java.util.Map">
SELECT
        SUM(total) as value,
			'未交费用' AS name
		FROM
			qwb_cost
		WHERE
			state = '0'
    </select>
 <!--以上是用于统计已交费和未交费的饼状图的查询语句-->

    <select id="selectQwbCostList" parameterType="QwbCost" resultMap="QwbCostResult">
        <include refid="selectQwbCostVo"/>
        <where>  
            <if test="id != null "> and id = #{id}</if>
             <if test="name != null  and name != '' "> and name = #{name}</if>
             <!--<if test="createDate != null  and createDate != '' "> and create_date = #{createDate}</if>-->

            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                AND date_format(create_date,'%y%m%d') &gt;= date_format(#{params.beginTime},'%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                AND date_format(create_date,'%y%m%d') &lt;= date_format(#{params.endTime},'%y%m%d')
            </if>

             <if test="electricityCosts != null "> and electricity_costs = #{electricityCosts}</if>
             <if test="waterCosts != null "> and water_costs = #{waterCosts}</if>
             <if test="gasCosts != null "> and gas_costs = #{gasCosts}</if>
             <if test="propertyCosts != null "> and property_costs = #{propertyCosts}</if>
             <if test="paymentTime != null  "> and payment_time = #{paymentTime}</if>
             <if test="state != null "> and state = #{state}</if>

            <!--==================================================-->
             <if test="room != null "> and room = #{room}</if>
            <!--<if test="check != null "> and `check` = #{check}</if>-->
            <if test="total != null "> and total = #{total}</if>
         </where>
    </select>
    
    <select id="selectQwbCostById" parameterType="Integer" resultMap="QwbCostResult">
        <include refid="selectQwbCostVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertQwbCost" parameterType="QwbCost" useGeneratedKeys="true" keyProperty="id">
        insert into qwb_cost
		<trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="name != null  and name != ''  ">name,</if>
			<if test="createDate != null    ">create_date,</if>
			<if test="electricityCosts != null  ">electricity_costs,</if>
			<if test="waterCosts != null  ">water_costs,</if>
			<if test="gasCosts != null  ">gas_costs,</if>
			<if test="propertyCosts != null  ">property_costs,</if>
			<!--<if test="paymentTime != null  and paymentTime != ''  ">payment_time,</if>-->
			<if test="state != null  ">state,</if>
            <if test="room != null  ">room,</if>
           <!-- <if test="check != null  ">`check`,</if>-->
            <if test="total != null  ">total,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="name != null  and name != ''  ">#{name},</if>
			<if test="createDate != null   ">#{createDate},</if>
			<if test="electricityCosts != null  ">#{electricityCosts},</if>
			<if test="waterCosts != null  ">#{waterCosts},</if>
			<if test="gasCosts != null  ">#{gasCosts},</if>
			<if test="propertyCosts != null  ">#{propertyCosts},</if>
			<!--<if test="paymentTime != null  and paymentTime != ''  ">#{paymentTime},</if>-->
			<if test="state != null  ">#{state},</if>
            <!--==================================================-->
            <if test="room != null  ">#{room},</if>
            <!--<if test="check != null  ">#{check},</if>-->
            <if test="total != null  ">#{total},</if>
         </trim>
    </insert>
	 
    <update id="updateQwbCost" parameterType="QwbCost">
        update qwb_cost
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null  and name != ''  ">name = #{name},</if>
            <if test="createDate != null    ">create_date = #{createDate},</if>
            <if test="electricityCosts != null  ">electricity_costs = #{electricityCosts},</if>
            <if test="waterCosts != null  ">water_costs = #{waterCosts},</if>
            <if test="gasCosts != null  ">gas_costs = #{gasCosts},</if>
            <if test="propertyCosts != null  ">property_costs = #{propertyCosts},</if>
            <if test="paymentTime != null   ">payment_time = #{paymentTime},</if>
            <if test="state != null  ">state = #{state},</if>
            <!--==================================================-->
            <if test="room != null  ">room = #{room},</if>
            <!--<if test="check != null  ">`check` = #{check},</if>-->
            <if test="total != null  ">total = #{total},</if>
        </trim>
        where id = #{id}
    </update>

	<delete id="deleteQwbCostById" parameterType="Integer">
        delete from qwb_cost where id = #{id}
    </delete>
	
    <delete id="deleteQwbCostByIds" parameterType="String">
        delete from qwb_cost where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
</mapper>